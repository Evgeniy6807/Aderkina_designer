anded","false"),n.querySelectorAll("a,button,input,select,textarea").forEach((function(e){e.dataset._tabindex=e.hasAttribute("tabindex")?e.getAttribute("tabindex"):"",e.setAttribute("tabindex","-1")})),a.setAttribute("aria-hidden","true");else{n.setAttribute("aria-hidden","false"),e.setAttribute("aria-expanded","true"),n.querySelectorAll("a,button,input,select,textarea").forEach((function(e){var t=e.dataset._tabindex;""===t?e.removeAttribute("tabindex"):t&&e.setAttribute("tabindex",t),delete e.dataset._tabindex})),a.setAttribute("aria-hidden","false");var i=n.querySelector("a,button,input");i&&i.focus()}}e.addEventListener("click",(function(t){t.preventDefault(),document.body.classList.toggle("menu-open"),i("true"===e.getAttribute("aria-expanded"))})),t.addEventListener("click",(function(t){t.preventDefault(),document.body.classList.remove("menu-open"),i(!0),e.focus()})),a.addEventListener("click",(function(){document.body.classList.remove("menu-open"),i(!0),e.focus()})),i(!0)}();</script> <main class="main-content"> <div class="container"><div class="wrapper"> <div class="mb-4"> <div class="dropzone-component"> <label for="fontInput" class="upload-label block mb-2 font-semibold"> Загрузить файл шрифта </label> <div id="fontInputDropZone" class="w-full p-5 mb-4 border-2 border-dashed rounded-md text-center" style="border-color:var(--accent); background:var(--bg);"> <div id="fontInputDropText" class="text-muted cursor-pointer"> Выберите файл шрифта... <div class="text-sm mt-2 text-muted">Или перетащите файл сюда</div> </div> </div> <input type="file" id="fontInput" accept=".ttf,.otf,.woff,.woff2" multiple class="hidden"></div> <p class="text-sm text-muted mt-2">Поддерживаемые форматы: TTF, OTF, WOFF</p> </div> <div class="flex gap-3 mb-4 flex-wrap"> <button id="btn-convert" class="btn-primary" disabled> Конвертировать в WOFF2 </button> <button id="btn-reset" class="btn"> Очистить </button> </div> <div id="file-list" class="hidden mb-4"></div> <div id="result-area" class="hidden"> <div class="flex justify-between items-center mb-3 flex-wrap gap-3"> <h3 class="text-lg font-semibold">Результат конвертации</h3> <div id="download-all-container" class="hidden"> <button id="btn-download-separate" class="btn"> Скачать отдельно </button> <button id="btn-download-zip" class="btn-primary"> Скачать ZIP </button> </div> </div> <div id="results-container"></div> </div></div><link rel="stylesheet" href="https://microapps.by/services/font-to-woff2/style.css"><script src="https://microapps.by/api/jszip" defer></script><script src="https://microapps.by/services/font-to-woff2/script.js" defer></script><article class="content" itemscope itemtype="https://schema.org/Article"> <h2 itemprop="headline">Что такое WOFF2 и зачем конвертировать шрифты?</h2> <div itemprop="author" itemscope itemtype="https://schema.org/Organization"> <meta itemprop="name" content="MicroApps Team"> <meta itemprop="url" content="https://microapps.by"> </div> <meta itemprop="publisher" content="MicroApps"> <div class="wrapper" itemprop="articleBody"> <p>WOFF2 (Web Open Font Format 2) — это современный формат веб-шрифтов с улучшенным сжатием. Он обеспечивает уменьшение размера файла на 30% по сравнению с WOFF и на 50% по сравнению с TTF/OTF. Это значительно ускоряет загрузку страниц и улучшает производительность сайта.</p> <p>Конвертация шрифтов в WOFF2 — обязательный этап оптимизации веб-проекта. Меньший размер файлов означает быструю загрузку, экономию трафика пользователей и лучшие показатели в Google PageSpeed. WOFF2 поддерживается всеми современными браузерами с 2016 года.</p> <p>Наш конвертер работает полностью онлайн без установки программ. Загрузите TTF, OTF или WOFF файл, получите оптимизированный WOFF2 за секунды. Все файлы обрабатываются на сервере и не сохраняются после конвертации.</p> </div></article><section class="howto" itemscope itemtype="https://schema.org/HowTo" aria-labelledby="howto-title"> <h2 id="howto-title">Как конвертировать шрифт в WOFF2</h2> <div class="howto-content"> <ul class="howto-steps grid gap-4 grid-cols-1 md:grid-cols-2"> <li itemscope itemtype="https://schema.org/HowToStep" itemprop="step" class="flex flex-col gap-6 card card--howto"> <div class="flex items-center gap-4"> <span class="rounded-full size-8 flex items-center justify-center bg-[var(--bg)] text-lg">1</span> <p class="text-xl font-medium" itemprop="name">Шаг 1</p> </div> <p itemprop="text" class="text-left">Загрузите файл шрифта (TTF, OTF или WOFF) через кнопку выбора или перетащите его в область загрузки.</p> </li> <li itemscope itemtype="https://schema.org/HowToStep" itemprop="step" class="flex flex-col gap-6 card card--howto"> <div class="flex items-center gap-4"> <span class="rounded-full size-8 flex items-center justify-center bg-[var(--bg)] text-lg">2</span> <p class="text-xl font-medium" itemprop="name">Шаг 2</p> </div> <p itemprop="text" class="text-left">Нажмите кнопку «Конвертировать в WOFF2» и дождитесь завершения обработки.</p> </li> <li itemscope itemtype="https://schema.org/HowToStep" itemprop="step" class="flex flex-col gap-6 card card--howto"> <div class="flex items-center gap-4"> <span class="rounded-full size-8 flex items-center justify-center bg-[var(--bg)] text-lg">3</span> <p class="text-xl font-medium" itemprop="name">Шаг 3</p> </div> <p itemprop="text" class="text-left">Скачайте конвертированный WOFF2 файл на свой компьютер. При загрузке нескольких файлов используйте «Скачать все».</p> </li> </ul> </div></section><section class="faq" id="faq" itemscope itemtype="https://schema.org/FAQPage"> <h2 itemprop="name">FAQ</h2> <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"> <button class="faq-question" aria-expanded="false" aria-controls="faq1"> <span itemprop="name">Какие форматы шрифтов можно конвертировать?</span> <svg class="faq-icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"> <path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/> </svg> </button> <div id="faq1" class="faq-answer" role="region" aria-hidden="true" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"> <p itemprop="text">Конвертер поддерживает TTF (TrueType Font), OTF (OpenType Font) и WOFF (Web Open Font Format). Все эти форматы успешно конвертируются в WOFF2.</p> </div> </div> <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"> <button class="faq-question" aria-expanded="false" aria-controls="faq2"> <span itemprop="name">Насколько WOFF2 меньше по размеру?</span> <svg class="faq-icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"> <path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/> </svg> </button> <div id="faq2" class="faq-answer" role="region" aria-hidden="true" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"> <p itemprop="text">WOFF2 обычно на 30% меньше WOFF и на 40-50% меньше TTF/OTF благодаря алгоритму сжатия Brotli. Для шрифта 100 КБ размер WOFF2 будет около 50-60 КБ.</p> </div> </div> <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"> <button class="faq-question" aria-expanded="false" aria-controls="faq3"> <span itemprop="name">Поддерживается ли WOFF2 всеми браузерами?</span> <svg class="faq-icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"> <path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/> </svg> </button> <div id="faq3" class="faq-answer" role="region" aria-hidden="true" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"> <p itemprop="text">Да, WOFF2 поддерживается всеми современными браузерами: Chrome 36+, Firefox 39+, Safari 10+, Edge 14+. Для старых браузеров можно подключить WOFF в качестве fallback.</p> </div> </div> <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"> <button class="faq-question" aria-expanded="false" aria-controls="faq4"> <span itemprop="name">Сохраняются ли мои файлы на сервере?</span> <svg class="faq-icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"> <path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/> </svg> </button> <div id="faq4" class="faq-answer" role="region" aria-hidden="true" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"> <p itemprop="text">Нет, все файлы обрабатываются в реальном времени и автоматически удаляются после конвертации. Мы не храним загруженные шрифты.</p> </div> </div> <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question"> <button class="faq-question" aria-expanded="false" aria-controls="faq5"> <span itemprop="name">Можно ли конвертировать несколько шрифтов сразу?</span> <svg class="faq-icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"> <path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/> </svg> </button> <div id="faq5" class="faq-answer" role="region" aria-hidden="true" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"> <p itemprop="text">Да, вы можете загрузить несколько файлов одновременно. После конвертации доступна кнопка «Скачать все» для пакетной загрузки в ZIP-архиве.</p> </div> </div> </section></div></main><footer class="w-full"> <p class='text-center'>&copy; MicroApps Platform </p></footer><script src="https://microapps.by/assets/js/site-ui.min.js" defer></script><script src="https://microapps.by/assets/js/search.min.js" defer></script><script src="https://microapps.by/assets/js/smart-nav.min.js" defer></script><script src="https://microapps.by/assets/js/analytics.js" defer></script></div></div></body></html>